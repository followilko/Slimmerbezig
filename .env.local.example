# Copy this file to `.env.local` and fill in your Supabase keys.
# Dashboard: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — server only (never NEXT_PUBLIC_*). Required for /onboarding and /checkin chat.
OPENAI_API_KEY=

# Optional: set to "true" to run tools in dry-run mode (no DB writes; useful before running supabase/ai_chat_schema.sql).
# AI_CHAT_STUB_TOOLS=
